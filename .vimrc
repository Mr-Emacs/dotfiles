syntax on
filetype plugin indent on
set tabstop=4
set shiftwidth=4
set expandtab
set guifont=Iosevka\ 20
set guioptions-=m
set guioptions-=T
set noesckeys
set number
set ignorecase
set smartcase
set incsearch
set cinoptions=l1
set modeline
set iminsert=0
set imsearch=0
set autoindent
set autochdir
colorscheme habamax
se foldmethod=manual
" Use default terminal colors
highlight Normal cterm=NONE ctermbg=NONE ctermfg=NONE
highlight NonText cterm=NONE ctermbg=NONE
highlight LineNr cterm=NONE ctermbg=NONE
highlight StatusLine cterm=NONE ctermbg=NONE
