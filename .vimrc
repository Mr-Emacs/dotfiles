syntax on
filetype plugin indent on
set tabstop=4
set shiftwidth=4
set expandtab
set guioptions-=m
set guioptions-=T
set noesckeys
set number
set ignorecase
set smartcase
set incsearch
set cinoptions=l1
set iminsert=0
set imsearch=0
set autoindent
autocmd BufEnter * silent! lcd %:p:h
set foldmethod=manual
set noswapfile
