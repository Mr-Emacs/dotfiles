# -*- mode: snippet -*-
# name: NOTE comment
# key: note
# --
`(let* ((prefix
         (cond
          ((derived-mode-p 'c-mode 'c++-mode 'simpc-mode) "// ")
          ((derived-mode-p 'python-mode) "# ")
          (t ""))))
   (replace-regexp-in-string "\n\\'" "" (concat prefix "NOTE(@Mr-segfault): ")))`$0