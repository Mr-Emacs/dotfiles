{
    "layer": "bottom",
    "position": "bottom",
    "height": 21,
    "spacing": 0,
    "exclusive": true,

    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["memory", "battery", "clock", "pulseaudio", "tray"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}"
    },

    "hyprland/submap": {
        "format": " {}"
    },

    "cpu": {
        "interval": 2,
        "format": "CPU: {usage}%",
        "tooltip": false
    },

    "memory": {
        "interval": 5,
        "format": "MEM: {used:0.1f}G/{total:0.1f}G",
        "on-click": "gnome-system-monitor",
        "tooltip": false
    },

    "disk": {
        "interval": 30,
        "format": "DISK: {percentage_used}%",
        "path": "/",
        "tooltip": false
    },

    "network": {
        "interval": 5,
        "format-wifi": "WIFI: {essid} ({signalStrength}%)",
        "format-ethernet": "ETH: {ipaddr}",
        "format-disconnected": "NET: disconnected",
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "󰝟",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "scroll-step": 5,
        "tooltip": false,
        "on-click": "pavucontrol"
    },

    "battery": {
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT: {capacity}%",
        "format-charging": "BAT: {capacity}% CHR",
        "format-full": "BAT: full",
        "tooltip": false
    },
    "clock": {
        "format": " {:%H:%M:%S}",
        "interval": 1,
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right"
        },
        "on-click": "gsimplecal"
    },

    "hyprland/window": {
        "format": "{class}: {title}",
        "max-length": 80,
        "tooltip": false
    },
    "tray": {
        "spacing": 6
    }
}
