{
    "layer": "bottom",
    "position": "bottom",
    "height": 20,
    "spacing": 0,
    "exclusive": true,

    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": [],
    "modules-right": ["cpu", "memory", "disk", "network", "battery", "clock", "tray"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}"
    },

    "hyprland/submap": {
        "format": " {}"
    },

    "cpu": {
        "interval": 2,
        "format": "CPU: {usage}%",
        "tooltip": false
    },

    "memory": {
        "interval": 5,
        "format": "MEM: {used:0.1f}G/{total:0.1f}G",
        "tooltip": false
    },

    "disk": {
        "interval": 30,
        "format": "DISK: {percentage_used}%",
        "path": "/",
        "tooltip": false
    },

    "network": {
        "interval": 5,
        "format-wifi": "WIFI: {essid} ({signalStrength}%)",
        "format-ethernet": "ETH: {ipaddr}",
        "format-disconnected": "NET: disconnected",
        "tooltip": false
    },

    "battery": {
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT: {capacity}% {status}",
        "format-charging": "BAT: {capacity}% CHR",
        "format-full": "BAT: full",
        "tooltip": false
    },

    "clock": {
        "interval": 60,
        "format": "{:%Y-%m-%d %H:%M}",
        "tooltip": false
    },

    "tray": {
        "spacing": 6
    }
}
